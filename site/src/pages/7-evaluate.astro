---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Evaluate" prev={`${base}6-pilot/`}>
  <div class="max-w-5xl mx-auto py-10 px-4 landing-content">

    <div class="mb-10" style="text-align: center; padding: 3rem 1rem;">
      <h1>This content has moved</h1>
      <p style="margin-top: 1rem;">
        Evaluation is now part of Step 6: Pilot. Your playbook includes success measures, targets and the Scale / Revise / Stop decision.
      </p>
      <a
        href={`${base}6-pilot/`}
        style="display: inline-block; margin-top: 1.5rem; padding: 0.6rem 1.5rem; border: 1px solid var(--purple); border-radius: 8px; color: var(--purple); font-weight: 600; text-decoration: none;"
      >
        Go to Step 6: Pilot &rarr;
      </a>
    </div>

  </div>
</BaseLayout>
