---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimplifiedInputs from '../components/SimplifiedInputs.tsx';
import PilotPlaybook from '../components/PilotPlaybook.tsx';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Step 6: Pilot" step={6} prev={`${base}5-bound/`}>
  <div class="max-w-5xl mx-auto py-10 px-4 landing-content">

    <div class="mb-10">
      <h1>Your pilot playbook</h1>
      <p class="subtitle">Everything you need to decide, assign, run, control and evaluate the pilot.</p>
    </div>

    <div class="mb-10">
      <h2>Cost and build</h2>
      <SimplifiedInputs client:load section="cost" />
    </div>

    <div class="divider"></div>

    <div class="mb-10">
      <PilotPlaybook client:load />
    </div>

    <div class="mb-10" style="padding: 1.25rem; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card);">
      <p style="font-size: 14px; color: var(--text-light); margin: 0;">
        <strong style="color: var(--text);">Need to look something up?</strong> The <a href={`${base}resources/`}>resources page</a> has detailed guidance on each qualification criterion, an explanation of the AI paradigms used in this guide and a glossary of technical terms.
      </p>
    </div>

    <div style="text-align: center; padding: 1rem 0;">
      <a href={`${base}5-bound/`} style="display: inline-block; padding: 0.5rem 1.25rem; border: 1px solid var(--purple); border-radius: 8px; color: var(--purple); font-weight: 600; text-decoration: none; font-size: 0.875rem;">&larr; Back to Bound</a>
    </div>

  </div>
</BaseLayout>

<style>
  .landing-content .subtitle {
    color: var(--text-light);
    font-size: 16px;
  }
</style>
