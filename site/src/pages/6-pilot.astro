---
import BaseLayout from '../layouts/BaseLayout.astro';
import PilotAssessment from '../components/PilotAssessment.tsx';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Step 6: Pilot" step={6} prev={`${base}5-bound/`} next={`${base}7-evaluate/`}>
  <div class="page-header">
    <h1>Pilot plan and assessment</h1>
    <p class="subtitle">Run the full assessment, review your scores, and get a concrete 30-day action plan.</p>
  </div>

  <div class="section">
    <h2>How the assessment works</h2>
    <p>The assessment combines your workflow mapping, qualification scoring, and readiness profile (if provided) to produce:</p>
    <ul class="output-list">
      <li><strong>Readiness score</strong> — how ready your org is for this workflow pilot</li>
      <li><strong>Qualification result</strong> — proceed, proceed with conditions, or defer</li>
      <li><strong>Action plan</strong> — prioritised steps for the next 30 days</li>
      <li><strong>Controls checklist</strong> — required controls from your readiness profile</li>
    </ul>

    <div class="pass-fail">
      <h3>Pass / Watch / Fail logic</h3>
      <p>A pilot is evaluated across 6 dimensions: time, cost, quality, risk, adoption friction, and control confidence.</p>
      <div class="pf-items">
        <div class="pf-item pass"><strong>Pass:</strong> improvement in ≥3 dimensions, no decline in risk or control confidence</div>
        <div class="pf-item watch"><strong>Watch:</strong> mixed results or one decline in a non-critical dimension</div>
        <div class="pf-item fail"><strong>Fail:</strong> decline in risk or control confidence, or major quality degradation</div>
      </div>
    </div>
  </div>

  <hr style="border: none; border-top: 1px solid var(--border); margin: 2rem 0;" />

  <div class="section">
    <h2>Your assessment results</h2>
    <PilotAssessment client:load />
  </div>
</BaseLayout>

<style>
  .output-list { padding-left: 1.25rem; margin-bottom: 1.5rem; }
  .output-list li { padding: 0.25rem 0; font-size: 0.9375rem; }
  .pass-fail { margin-top: 1.5rem; }
  .pf-items { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.75rem; }
  .pf-item { padding: 0.75rem 1rem; border-radius: var(--radius); font-size: 0.875rem; }
  .pf-item.pass { background: rgba(34, 197, 94, 0.08); border-left: 3px solid var(--success); }
  .pf-item.watch { background: rgba(245, 158, 11, 0.08); border-left: 3px solid var(--warning); }
  .pf-item.fail { background: rgba(239, 68, 68, 0.08); border-left: 3px solid var(--danger); }
</style>
