---
import BaseLayout from '../layouts/BaseLayout.astro';
import BoundaryChecklist from '../components/BoundaryChecklist.tsx';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Step 5: Bound" step={5} prev={`${base}4-map/`} next={`${base}6-pilot/`}>
  <div class="page-header">
    <h1>Design boundaries and controls</h1>
    <p class="subtitle">Define what is deterministic vs generative, what must stay human, and where approval gates go.</p>
  </div>

  <div class="section">
    <h2>Why boundaries matter</h2>
    <p>LLMs are powerful but unreliable in specific ways. Boundaries translate known limitations into design choices:</p>

    <div class="limits-grid">
      <div class="limit-card">
        <strong>Hallucination</strong>
        <p>Plausible but wrong output. Source traceability should be mandatory for factual claims.</p>
      </div>
      <div class="limit-card">
        <strong>Weak determinism</strong>
        <p>High-stakes numeric calculation should be deterministic, not generative.</p>
      </div>
      <div class="limit-card">
        <strong>Inconsistency</strong>
        <p>Output varies across runs. Confidence should never be treated as correctness.</p>
      </div>
      <div class="limit-card">
        <strong>Prompt sensitivity</strong>
        <p>Quality varies with phrasing. Externally shared outputs require human approval.</p>
      </div>
    </div>

    <h3 style="margin-top: 1.5rem;">Design patterns</h3>
    <ul class="pattern-list">
      <li>Deterministic core + LLM narrative layer</li>
      <li>Retrieval with citations for factual tasks</li>
      <li>Approval gates before irreversible actions</li>
      <li>Disallowed action list for agent/tool permissions</li>
    </ul>
  </div>

  <hr style="border: none; border-top: 1px solid var(--border); margin: 2rem 0;" />

  <div class="section">
    <h2>Your boundary checklist</h2>
    <p>Review and confirm each boundary consideration generated from your workflow mapping.</p>
    <BoundaryChecklist client:load />
  </div>
</BaseLayout>

<style>
  .limits-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem; }
  .limit-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; }
  .limit-card strong { font-size: 0.9375rem; }
  .limit-card p { font-size: 0.8125rem; color: var(--text-light); margin: 0.25rem 0 0; }
  .pattern-list { padding-left: 1.25rem; }
  .pattern-list li { font-size: 0.9375rem; color: var(--text-light); padding: 0.25rem 0; }
  @media (max-width: 480px) { .limits-grid { grid-template-columns: 1fr; } }
</style>
