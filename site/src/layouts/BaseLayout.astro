---
import '../styles/global.css';
import StepNav from '../components/StepNav.astro';
import ChevronNav from '../components/ChevronNav.astro';

interface Props {
  title: string;
  step?: number;
  prev?: string;
  next?: string;
}

const { title, step, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;

const stepLabels: Record<string, string> = {
  '1-discover': 'Discover',
  '2-select': 'Select',
  '3-qualify': 'Qualify',
  '4-map': 'Map',
  '5-bound': 'Bound',
  '6-pilot': 'Pilot',
  '7-evaluate': 'Evaluate',
};

function getNextLabel(href: string | undefined): string {
  if (!href) return '';
  const slug = href.replace(base, '').replace(/\/$/, '');
  return stepLabels[slug] || 'Next';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — adoption-eval</title>
  <link rel="icon" type="image/png" href={`${base}favicon.png`} />
  <script data-goatcounter="https://adoption-eval.goatcounter.com/count"
          async src="//gc.zgo.at/count.js"></script>
</head>
<body>
  <StepNav currentStep={step ?? 0} base={base} />

  {prev && <ChevronNav direction="prev" href={prev} />}
  {next && <ChevronNav direction="next" href={next} />}

  <aside class="sidebar">
    <div class="sidebar-inner">
      <div class="sidebar-section">
        <p class="sidebar-heading">Connect</p>
        <a href="https://kevinwtz404.github.io/kevin-witzenberger/" target="_blank" rel="noopener">Portfolio</a>
        <a href="mailto:kevin.witzenberger@posteo.de">Email</a>
        <a href="https://linkedin.com/in/kevin-witzenberger/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://genai-arcade.net" target="_blank" rel="noopener">GenAI Arcade</a>
        <a href="https://scholar.google.com.au/citations?user=rzyG0ucAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
        <a href="https://github.com/kevinwtz404/adoption-eval" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </aside>

  <main class="page-content">
    <div class="max-w-4xl mx-auto px-6">
      <slot />
    </div>
  </main>

  {next && (
    <div class="bottom-nav">
      <a href={next} class="bottom-nav-link">Next: {getNextLabel(next)} →</a>
    </div>
  )}

  <footer class="site-footer">
    <div class="max-w-4xl mx-auto px-6">
      adoption-eval &middot; kevin witzenberger
      &middot; <button class="privacy-link" onclick="document.getElementById('privacy-modal').showModal()">Data &amp; Privacy</button>
    </div>
  </footer>

  <dialog id="privacy-modal" class="modal">
    <div class="modal-box max-w-lg">
      <h3 class="text-lg font-bold mb-3" style="color: var(--purple);">Data &amp; Privacy</h3>

      <p class="mb-3">This tool is a research prototype. It does not collect personal data, use cookies, or require sign-in.</p>

      <h4 class="font-semibold mb-1">What stays in your browser</h4>
      <p class="mb-3">Everything you enter is saved in your browser's local storage. Nothing is sent to a server unless you explicitly request AI analysis.</p>

      <h4 class="font-semibold mb-1">AI analysis</h4>
      <p class="mb-3">When you use the AI features, your workflow description is sent to Google Gemini via a proxy. Prompts and responses are not logged — only your IP address is recorded for rate limiting.</p>

      <h4 class="font-semibold mb-1">Analytics</h4>
      <p class="mb-3">Page views are tracked with <a href="https://www.goatcounter.com" target="_blank" rel="noopener">GoatCounter</a>, a privacy-friendly analytics tool. No personal data is collected.</p>

      <h4 class="font-semibold mb-1">Important</h4>
      <p><strong>Do not enter personal or identifying information.</strong> This tool is designed for describing work processes, not people. Treat all text fields as public.</p>

      <div class="modal-action">
        <form method="dialog">
          <button class="btn btn-sm">Close</button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
</body>
</html>
