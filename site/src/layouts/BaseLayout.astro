---
import '../styles/global.css';
import StepNav from '../components/StepNav.astro';
import ChevronNav from '../components/ChevronNav.astro';

interface Props {
  title: string;
  step?: number;
  prev?: string;
  next?: string;
}

const { title, step, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — adoption-eval</title>
  <link rel="icon" href={`${base}favicon.ico`} />
</head>
<body>
  <StepNav currentStep={step ?? 0} base={base} />

  {prev && <ChevronNav direction="prev" href={prev} />}
  {next && <ChevronNav direction="next" href={next} />}

  <aside class="sidebar">
    <div class="sidebar-inner">
      <div class="sidebar-section">
        <p class="sidebar-heading">Connect</p>
        <a href="mailto:kevin.witzenberger@posteo.de">Email</a>
        <a href="https://linkedin.com/in/kevin-witzenberger/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://genai-arcade.net" target="_blank" rel="noopener">GenAI Arcade</a>
        <a href="https://scholar.google.com.au/citations?user=rzyG0ucAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
        <a href="https://kevinwtz404.github.io/kevin-witzenberger/portfolio" target="_blank" rel="noopener">Portfolio</a>
        <a href="https://github.com/kevinwtz404/adoption-eval" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </aside>

  <main class="page-content">
    <div class="max-w-4xl mx-auto px-6">
      <slot />
    </div>
  </main>

  <footer class="site-footer">
    <div class="max-w-4xl mx-auto px-6">
      adoption-eval &middot; kevin witzenberger
    </div>
  </footer>
</body>
</html>
